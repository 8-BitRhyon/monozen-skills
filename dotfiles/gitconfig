[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
[user]
	name = $NAME                 # TODO: set your name
	email = $GITHUB_NOREPLY_EMAIL # TODO: set your GitHub noreply email
	signingkey = $GPG_KEY_ID      # TODO: set your GPG key ID (`gpg --list-secret-keys --keyid-format=long`)
[core]
	editor = nvim
	excludesfile = ~/.gitignore_global
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	side-by-side = true
	line-numbers = true
	features = decorations
[delta "decorations"]
	commit-decoration-style = blue ol
	file-style = bold yellow
	file-decoration-style = none
	hunk-header-decoration-style = cyan
[merge]
	conflictstyle = zdiff3
[fetch]
	prune = true
[push]
	autoSetupRemote = true
[commit]
	gpgsign = true
[tag]
	gpgsign = true
